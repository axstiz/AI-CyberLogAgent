# Database Configuration
POSTGRES_VERSION=18
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=cyberlog_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cyberlog_password

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=False

# Security Configuration
PASSWORD_SALT=SALT

# Frontend Configuration
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# Container Names
DB_CONTAINER_NAME=cyberlog-db
BACKEND_CONTAINER_NAME=cyberlog-backend
FRONTEND_CONTAINER_NAME=cyberlog-frontend

# GIGAChat API (cloud fallback)
GIGACHAT_API_KEY=gigachat_api_key
GIGACHAT_MODEL=GigaChat-2-Max

# OLLAMA (on-premise / local server — priority over GigaChat)
# URL вашего Ollama сервера, например: http://192.168.1.100:11434
# Для тестов на localhost: http://localhost:11434
OLLAMA_URL=
OLLAMA_MODEL=example_qwen2.5:7b

# LLM общие настройки
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000
LLM_TIMEOUT=90

# Kafka/Vector Pipeline Configuration
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_PORT=9092
KAFKA_TOPIC=processed-logs-batches
KAFKA_GROUP_ID=cyberlog-backend-group
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_PROCESS_RETRY_ATTEMPTS=3
KAFKA_RETRY_BACKOFF_SECONDS=2
KAFKA_DLQ_ENABLED=true
KAFKA_DLQ_TOPIC=processed-logs-batches-dlq
KAFKA_CONTAINER_NAME=cyberlog-kafka
VECTOR_CONTAINER_NAME=cyberlog-vector
VECTOR_DATA_VOLUME_NAME=cyberlog_vector_data
CHUNK_BATCH_SIZE=250
CHUNK_OVERLAP=20
CHUNK_FLUSH_INTERVAL_SECONDS=300

# Shared paths in containers for pipeline stages
PIPELINE_EXTERNAL_LOGS_DIR=/app/shared/external
PIPELINE_PROCESSED_LOGS_DIR=/app/shared/processed
PIPELINE_COLLECTED_LOGS_FILE=/app/shared/processed/collected_logs.txt
PIPELINE_CONSUMED_LOGS_FILE=/app/shared/processed/kafka_consumed_logs.jsonl
PIPELINE_KAFKA_AUTO_ANALYZE=true

# Shared Docker volumes for cross-project log ingestion
PIPELINE_EXTERNAL_LOGS_VOLUME_NAME=cyberlog_external_logs
PIPELINE_PROCESSED_LOGS_VOLUME_NAME=cyberlog_processed_logs

# Timezone Configuration
CLI_TZ_OFFSET_HOURS=5