# Database Configuration
POSTGRES_VERSION=18
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=cyberlog_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cyberlog_password

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=False

# Security Configuration
PASSWORD_SALT=SALT

# HuggingFace токен для скачивания моделей (ускоренное скачивание)
HF_TOKEN=

# Frontend Configuration
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# SaluteSpeech (backend proxy)
# Authorization key for OAuth (Basic <Authorization key>)
VITE_SBER_SPEECH_API_KEY=
VITE_SBER_SPEECH_API_URL=https://smartspeech.sber.ru/rest/v1/speech:recognize
VITE_SBER_SPEECH_VALIDATE_URL=https://smartspeech.sber.ru/rest/v1/text:synthesize
VITE_SBER_SPEECH_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
VITE_SBER_SPEECH_SCOPE=SALUTE_SPEECH_PERS

# Container Names
DB_CONTAINER_NAME=cyberlog-db
BACKEND_CONTAINER_NAME=cyberlog-backend
FRONTEND_CONTAINER_NAME=cyberlog-frontend

# OLLAMA
# URL вашего Ollama сервера, например: http://192.168.1.100:11434
# Для тестов на localhost: http://localhost:11434
# Для локального с docker: http://host.docker.internal:11434
OLLAMA_URL=
OLLAMA_MODEL=example_qwen2.5:7b

# AITUNNEL — единый API для доступа к нейросетям (OpenAI-совместимый)
# Документация: https://aitunnel.ru
# Зарегистрироваться: https://aitunnel.ru, пополнить баланс, создать API ключ
AITUNNEL_API_KEY=sk-aitunnel-xxx
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1
AITUNNEL_MODEL=deepseek-v4-flash

# LLM общие настройки
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
AI_V2_MAX_ANALYSIS_LOG_CHARS=8000
LLM_TIMEOUT=180

# Prefilter Sampling Rate (0.0-1.0, default 0.4 = 40% for non-security logs)
AI_V2_SAMPLING_RATE=0.4

# RAG
AI_V2_RAG_THRESHOLD=0.7

# Kafka/Vector Pipeline Configuration
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_PORT=9092
KAFKA_TOPIC=processed-logs-batches
KAFKA_GROUP_ID=cyberlog-backend-group
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_PROCESS_RETRY_ATTEMPTS=3
KAFKA_RETRY_BACKOFF_SECONDS=2
KAFKA_DLQ_ENABLED=true
KAFKA_DLQ_TOPIC=processed-logs-batches-dlq
KAFKA_CONTAINER_NAME=cyberlog-kafka
VECTOR_CONTAINER_NAME=cyberlog-vector
VECTOR_DATA_VOLUME_NAME=cyberlog_vector_data
CHUNK_BATCH_SIZE=250
CHUNK_OVERLAP=20
CHUNK_FLUSH_INTERVAL_SECONDS=300
CHUNK_STATE_FILE_BACKEND=/app/shared/external/chunk_logs_state.tsv
CHUNK_STATE_FILE_VECTOR=/data/external/chunk_logs_state.tsv

# Shared paths in containers for pipeline stages
PIPELINE_EXTERNAL_LOGS_DIR=/app/shared/external
PIPELINE_EXTERNAL_APPEND_FILE=/app/shared/external/external_stream.log
PIPELINE_PROCESSED_LOGS_DIR=/app/shared/processed
PIPELINE_COLLECTED_LOGS_FILE=/app/shared/processed/collected_logs.txt
PIPELINE_CONSUMED_LOGS_FILE=/app/shared/processed/kafka_consumed_logs.jsonl
PIPELINE_KAFKA_AUTO_ANALYZE=true

# Shared Docker volumes for cross-project log ingestion
PIPELINE_EXTERNAL_LOGS_VOLUME_NAME=cyberlog_external_logs
PIPELINE_PROCESSED_LOGS_VOLUME_NAME=cyberlog_processed_logs

# Timezone Configuration
CLI_TZ_OFFSET_HOURS=5